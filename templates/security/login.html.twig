{% extends 'base.html.twig' %}

{% block title %}LocalBox // AUTHENTICATION{% endblock %}

{% block main %}
    <section class="flex min-h-dvh flex-col items-center justify-center">
        {{ include('partials/header.html.twig') }}
        <div class="flex w-full max-w-2xl flex-col border border-zinc-800 border-solid bg-zinc-900">
            <section class="flex flex-col">
                <header class="flex items-center justify-between px-4 py-8 md:px-8">
                    <h2 class="font-bold font-inter text-brand text-xs uppercase tracking-widest">
                        authentication
                    </h2>
                    <span class="bg-zinc-950/25 px-4 py-2 font-space-mono text-xs text-zinc-300 uppercase">
                        secure access
                    </span>
                </header>
                <div class="flex flex-col gap-4 bg-zinc-950/25 px-4 py-4 md:px-8">
                    {% if error %}
                        <div class="flex flex-col gap-2 border border-red-800 bg-red-950 p-4 text-center">
                            <p class="font-bold font-inter text-red-400 text-xs uppercase tracking-widest">
                                authentication error
                            </p>
                            <p class="font-mono-space text-red-300 text-sm">
                                {{ error.messageKey|trans(error.messageData, 'security') }}
                            </p>
                        </div>
                    {% endif %}
                    {% if app.user %}
                        <div class="flex flex-col gap-2 border border-emerald-800 bg-emerald-950 p-4 text-center">
                            <p class="font-bold font-inter text-emerald-400 text-xs uppercase tracking-widest">
                                authenticated
                            </p>
                            <p class="font-mono-space text-emerald-300 text-sm">
                                you are logged in as {{ app.user.userIdentifier }}
                            </p>
                        </div>
                    {% endif %}
                    <form method="post" class="flex flex-col gap-4">
                        <div class="flex flex-col gap-2">
                            <label for="username" class="font-bold font-inter text-xs text-zinc-300 uppercase tracking-widest">
                                username
                            </label>
                            <input type="text" name="_username" id="username" autocomplete="username" value="{{ last_username }}" class="border border-zinc-800 bg-zinc-950/25 p-4 font-mono-space text-sm text-zinc-300 outline-none transition-colors focus:border-brand focus:bg-zinc-950/50" required autofocus />
                        </div>
                        <div class="flex flex-col gap-2">
                            <label for="password" class="font-bold font-inter text-xs text-zinc-300 uppercase tracking-widest">
                                password
                            </label>
                            <input type="password" name="_password" id="password" autocomplete="current-password" class="border border-zinc-800 bg-zinc-950/25 p-4 font-mono-space text-sm text-zinc-300 outline-none transition-colors focus:border-brand focus:bg-zinc-950/50" required />
                        </div>
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}" data-controller="csrf-protection" />
                        <button type="submit" class="cursor-pointer bg-brand px-12 py-4 font-bold font-inter text-xs text-zinc-950 uppercase tracking-widest transition-transform hover:brightness-125">
                            sign in
                        </button>
                    </form>
                </div>
            </section>
        </div>
    </section>
{% endblock %}
