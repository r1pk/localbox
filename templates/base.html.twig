<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}LocalBox{% endblock %}</title>
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}{% endblock %}
        {% block importmap %}
            {{ importmap('app') }}
        {% endblock %}
    </head>
    <body class="relative bg-zinc-950 text-zinc-100 antialiased">
        <div class="bg-radial-gradient-pattern absolute inset-0 -z-1"></div>
        {% block body %}
            <main class="container mx-auto px-4">
                {% block main %}{% endblock %}
            </main>
        {% endblock %}
    </body>
</html>
