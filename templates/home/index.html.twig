{% extends 'base.html.twig' %}

{% block main %}
    <section class="flex min-h-dvh flex-col items-center justify-center" data-controller="dropzone" data-dropzone-preview-list-item-template-value="{{ include('partials/upload_preview_item.html.twig')|e('html_attr') }}">
        {{ include('partials/header.html.twig') }}
        <div class="flex w-full max-w-2xl flex-col border border-zinc-800 border-solid bg-zinc-900">
            <form action="{{ path('app_file_upload') }}" class="bg-zinc-950/25 p-4 transition-all" data-dropzone-target="uploadFormContainer">
                <div class="flex flex-col items-center justify-center gap-4 border border-zinc-800 border-dashed p-8 transition-colors">
                    <div class="text-brand">
                        <svg width="64" height="64" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="currentColor">
                            <path d="M12.5535 2.49392C12.4114 2.33852 12.2106 2.25 12 2.25C11.7894 2.25 11.5886 2.33852 11.4465 2.49392L7.44648 6.86892C7.16698 7.17462 7.18822 7.64902 7.49392 7.92852C7.79963 8.20802 8.27402 8.18678 8.55352 7.88108L11.25 4.9318V16C11.25 16.4142 11.5858 16.75 12 16.75C12.4142 16.75 12.75 16.4142 12.75 16V4.9318L15.4465 7.88108C15.726 8.18678 16.2004 8.20802 16.5061 7.92852C16.8118 7.64902 16.833 7.17462 16.5535 6.86892L12.5535 2.49392Z"></path>
                            <path d="M3.75 15C3.75 14.5858 3.41422 14.25 3 14.25C2.58579 14.25 2.25 14.5858 2.25 15V15.0549C2.24998 16.4225 2.24996 17.5248 2.36652 18.3918C2.48754 19.2919 2.74643 20.0497 3.34835 20.6516C3.95027 21.2536 4.70814 21.5125 5.60825 21.6335C6.47522 21.75 7.57754 21.75 8.94513 21.75H15.0549C16.4225 21.75 17.5248 21.75 18.3918 21.6335C19.2919 21.5125 20.0497 21.2536 20.6517 20.6516C21.2536 20.0497 21.5125 19.2919 21.6335 18.3918C21.75 17.5248 21.75 16.4225 21.75 15.0549V15C21.75 14.5858 21.4142 14.25 21 14.25C20.5858 14.25 20.25 14.5858 20.25 15C20.25 16.4354 20.2484 17.4365 20.1469 18.1919C20.0482 18.9257 19.8678 19.3142 19.591 19.591C19.3142 19.8678 18.9257 20.0482 18.1919 20.1469C17.4365 20.2484 16.4354 20.25 15 20.25H9C7.56459 20.25 6.56347 20.2484 5.80812 20.1469C5.07435 20.0482 4.68577 19.8678 4.40901 19.591C4.13225 19.3142 3.9518 18.9257 3.85315 18.1919C3.75159 17.4365 3.75 16.4354 3.75 15Z"></path>
                        </svg>
                    </div>
                    <p class="font-bold font-inter text-2xl text-zinc-100 tracking-tight md:text-3xl">
                        Drop files here
                    </p>
                    <div class="flex items-center justify-center gap-3">
                        <hr class="h-px w-4 border-zinc-700" />
                        <span class="font-inter font-medium text-xs text-zinc-300 uppercase tracking-wide">
                            or select from system
                        </span>
                        <hr class="h-px w-4 border-zinc-700" />
                    </div>
                    <button type="button" class="cursor-pointer bg-brand px-12 py-4 font-bold font-inter text-xs text-zinc-950 uppercase tracking-widest transition-transform hover:brightness-125" data-dropzone-target="uploadSelectButton">
                        select files
                    </button>
                </div>
                <input type="hidden" name="group_token" value="{{ group_token }}" />
            </form>
            <section class="hidden opacity-0 transition-opacity" data-dropzone-target="uploadPreviewContainer">
                <div class="flex flex-col">
                    <header class="flex items-center justify-between px-4 py-8 md:px-8">
                        <h2 class="font-bold font-inter text-brand text-xs uppercase tracking-widest">
                            transfer queue
                        </h2>
                        <span class="bg-zinc-950/25 px-4 py-2 font-space-mono text-xs text-zinc-300 uppercase" data-dropzone-target="uploadPreviewFileCountLabel">
                            files: 000
                        </span>
                    </header>
                    <ul class="space-y-2 bg-zinc-950/25 px-4 py-4 md:px-8" data-dropzone-target="uploadPreviewList"></ul>
                </div>
            </section>
            {{ include('partials/footer.html.twig') }}
        </div>
    </section>
{% endblock %}
